PORT=3000
# Telegram WebApp button requires HTTPS.
# For local dev with bot -> use ngrok URL here (recommended).
# If you set http://localhost:3000, bot will show a normal "open site" link (not WebApp button).
BASE_URL=https://your-domain-or-ngrok-url.example

# Docker publish port on the host (web container 3000 -> host 18080 by default).
# Nginx should proxy to http://127.0.0.1:18080
HOST_WEB_PORT=18080

# Telegram
BOT_TOKEN=123456:ABCDEF_your_bot_token_here
ADMIN_TELEGRAM_ID=123456789
SESSION_SECRET=change-this-to-random-string

# Payment card shown to users
CARD_NUMBER=8600 xxxx xxxx xxxx

# SQLite file path
DB_PATH=./db.sqlite

# Development helper: if WebApp initData is missing, allow a fake telegram id.
# Only used when NODE_ENV=development
DEV_TELEGRAM_ID=111111111
