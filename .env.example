PORT=4000
BASE_URL=https://your-domain-or-ngrok-url.example

SESSION_SECRET=change-this-to-random-string

# SMTP settings for password reset email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Road Test <no-reply@example.com>

# Payment card shown to users
CARD_NUMBER=8600 xxxx xxxx xxxx

# App connection string for local PostgreSQL
DATABASE_URL=postgresql:///avtotest
